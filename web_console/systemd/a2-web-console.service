[Unit]
Description=A2 ROS2 Web Console
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=unitree
WorkingDirectory=/home/unitree/ws/device-navigation/web_console
Environment=PYTHONUNBUFFERED=1
Environment=A2_WORKSPACE=/home/unitree/ws/device-navigation
Environment=A2_NETWORK_INTERFACE=net1
Environment=RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
Environment=CONFIG_PATH=/home/unitree/ws/device-navigation/web_console/backend/config.3d.yaml
ExecStart=/bin/bash -lc '/home/unitree/ws/device-navigation/web_console/scripts/run_backend.sh'
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
