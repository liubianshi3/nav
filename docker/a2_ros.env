# A2 ROS/DDS defaults used by docker-compose.a2.yml.
#
# Keep ROS_DOMAIN_ID fixed at 0 so external ROS tools with default settings can
# discover the A2 graph.
ROS_DOMAIN_ID=0
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

# Bind CycloneDDS to the A2 Wi-Fi/LAN interface used for external ROS tools.
A2_ROS_INTERFACE=wlxe865d4707bf8

# Optional comma/space-separated unicast peers for RViz/debug clients when LAN
# multicast discovery is unreliable. Keep empty for normal subnet discovery.
A2_ROS_PEERS=
